---
interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;

const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const links = isEn
  ? [
      { label: 'About',    href: `${base}/#about` },
      { label: 'Events',   href: `${base}/#events` },
      { label: 'Column',   href: `${base}/#column` },
      { label: 'Donation', href: `${base}/#donate` },
      { label: 'Contact',  href: `${base}/#contact` },
    ]
  : [
      { label: '關於我們', href: '#about' },
      { label: '實體活動', href: '#events' },
      { label: '專欄',     href: '#column' },
      { label: '捐款資訊', href: '#donate' },
      { label: '聯絡',     href: '#contact' },
    ];
---

<nav class="nav">
  <a href={isEn ? '/en/' : '/'} class="nav-logo-link">
    <img
      class="brand-logo"
      src="/logo-tiya-horizontal.png"
      alt="新二代留聲機 移民青年倡議陣線 logo"
    />
  </a>
  <div class="nav-items">
    {links.map(l => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    height: 300px;        /* fixed compact bar */
    overflow: hidden;    /* clips the tall logo — shows centre strip only */
    padding: 0 48px;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
  }

  .nav-logo-link {
    flex-shrink: 0;
    display: block;
    line-height: 0;
    margin-left: 15%;
  }

  .brand-logo {
    height: 450px;
    width: auto;
    max-width: 700px;
    display: block;
    /* blend white/cream logo bg into cream nav bg */
    mix-blend-mode: multiply;
  }

  .nav-items {
    /* Sits close to the logo, not pushed to far right */
    margin-left: 56px;
    display: flex;
    gap: 0;
    align-items: center;
    font-size: 13px;
    color: var(--ink-soft);
    /* Vertical separator between logo and links */
    border-left: 1px solid var(--line);
    padding-left: 48px;
  }

  .nav-items a {
    position: relative;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    padding: 6px 20px;
    white-space: nowrap;
    letter-spacing: 0.04em;
    transition: color 0.18s;
  }

  /* Sliding underline from centre */
  .nav-items a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20px;
    right: 20px;
    height: 2px;
    background: var(--terra);
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }

  .nav-items a:hover {
    color: var(--terra-deep);
  }

  .nav-items a:hover::after {
    transform: scaleX(1);
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .nav {
      height: auto;
      flex-direction: column;
      padding: 4px 16px 6px;
      gap: 0;
    }

    .nav-logo-link {
      margin-left: 0;
      width: 100%;
      max-width: 460px;
      /* Crop down to the actual content area of the PNG (which is the
         top ~40% of the image; the rest is transparent whitespace). */
      aspect-ratio: 460 / 145;
      display: block;
    }

    .brand-logo {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center 22%;
    }

    .nav-items {
      margin-left: 0;
      padding-left: 0;
      border-left: 0;
      flex-wrap: wrap;
      justify-content: center;
      gap: 4px 0;
      font-size: 12px;
    }

    .nav-items a {
      padding: 4px 12px;
    }
  }
</style>
