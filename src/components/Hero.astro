---
import { Image } from 'astro:assets';
import heroBanner from '../assets/hero-banner.png';

interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;
const isEn = lang === 'en';
---

<section class="hero">
  <!-- Banner: sits on right side only, does NOT fill full width -->
  <Image
    class="hero-bg"
    src={heroBanner}
    alt="對話・人權・倡議・共榮"
    widths={[400, 800, 1200, 1600]}
    sizes="(max-width: 768px) 100vw, 52vw"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Gradient: solid orange on left (text area), fades to transparent on right -->
  <div class="hero-overlay"></div>

  <div class="hero-content">
    {isEn ? (
      <>
        <h1>New Generation Phonograph</h1>
        <h2>Taiwan Immigration Youth Alliance</h2>
        <div class="hero-eng">新二代留聲機 · 移民青年倡議陣線</div>
        <div class="hero-rule"></div>
        <p>
          An advocacy group led by second-generation immigrants in Taiwan.
          We amplify the voices of immigrant youth, new residents, and new
          generations through dialogue, human rights, advocacy, and shared flourishing.
        </p>
      </>
    ) : (
      <>
        <h1>新二代留聲機</h1>
        <h2>移民青年倡議陣線</h2>
        <div class="hero-eng">Taiwan Immigration Youth Alliance</div>
        <div class="hero-rule"></div>
        <p>
          由在臺移民第二代為主體所組成的倡議團體。我們以同時作為臺灣青年與移民二代的視角，
          關注台灣社會的移民工議題，以及新住民、新二代群體的多樣性。
        </p>
      </>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--orange);
    min-height: 62vh;
    display: flex;
    align-items: center;
  }

  /* Image anchored to RIGHT edge, width ~50% → "往右靠、縮小" */
  .hero-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 52%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    animation: heroZoom 12s ease-in-out infinite alternate;
    transform-origin: center center;
  }

  @keyframes heroZoom {
    from { transform: scale(1); }
    to   { transform: scale(1.08); }
  }

  /* Gradient: opaque orange on left, fades where image begins */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--orange) 0%,
      var(--orange) 36%,
      rgba(239, 159, 39, 0.6) 52%,
      rgba(239, 159, 39, 0) 68%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 72px 64px 80px;
    max-width: 560px;
    color: white;
    margin-left: 10%;
  }

  .hero-content h1 {
    font-family: 'Noto Serif TC', serif;
    font-size: 52px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
    color: white;
  }

  .hero-content h2 {
    font-family: 'Noto Serif TC', serif;
    font-size: 30px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
    color: white;
  }

  .hero-eng {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.04em;
    opacity: 0.92;
  }

  .hero-rule {
    width: 60px;
    height: 2px;
    background: white;
    margin: 26px 0;
  }

  .hero-content p {
    font-size: 16px;
    line-height: 1.9;
    opacity: 0.96;
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
    }

    /* Banner full-bleed as visible backdrop, blended with orange */
    .hero-bg {
      width: 100%;
      opacity: 0.35;
      animation: none;
    }

    /* Lighter orange wash — photos visible, text still legible */
    .hero-overlay {
      background: linear-gradient(
        to bottom,
        rgba(239, 159, 39, 0.45) 0%,
        rgba(239, 159, 39, 0.7) 100%
      );
    }

    .hero-content {
      padding: 40px 24px 48px;
      margin-left: 0;
      max-width: 100%;
    }

    .hero-content h1 {
      font-size: 36px;
      margin-bottom: 8px;
    }

    .hero-content h2 {
      font-size: 22px;
      margin-bottom: 14px;
    }

    .hero-eng {
      font-size: 16px;
    }

    .hero-rule {
      margin: 18px 0;
    }

    .hero-content p {
      font-size: 14px;
      line-height: 1.85;
    }
  }
</style>
