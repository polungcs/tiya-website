---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoPhonograph from '../assets/logo-phonograph.png';

interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;
const isEn = lang === 'en';

const all = await getCollection('columns', ({ data }) => data.featured !== false);
// Oldest first → preserves the 01/02/03 reading order users expect for a series
const articles = all
  .sort((a, b) => a.data.publishedDate.getTime() - b.data.publishedDate.getTime())
  .map((entry, i) => ({
    num: String(i + 1).padStart(2, '0'),
    href: entry.data.url,
    title: entry.data.titleZh,
    titleEn: entry.data.titleEn,
    author: entry.data.authorZh,
    authorEn: entry.data.authorEn,
    image: entry.data.image,
    imageAlt: isEn ? (entry.data.imageAltEn ?? entry.data.titleEn) : (entry.data.imageAltZh ?? entry.data.titleZh),
  }));
---

<section class="section warm" id="column">
  <div class="container">
    <h2 class="section-h">
      {isEn ? 'CommonWealth Column' : '天下獨立評論專欄'}
      <span class="accent">column</span>
    </h2>

    <div class="column-layout">
      <!-- Articles side -->
      <div class="articles-side">
        <div class="cw-header">
          <span class="cw-badge">獨立評論@天下</span>
          <a href="https://opinion.cw.com.tw/blog/profile/531" target="_blank" rel="noopener">
            {isEn ? 'View all articles →' : '查看全部文章 →'}
          </a>
        </div>

        <div class="articles-list">
          {articles.map(a => (
            <a class="article" href={a.href} target="_blank" rel="noopener">
              <div class="article-num">{a.num}</div>
              {a.image && (
                <div class="article-thumb">
                  <img src={a.image} alt={a.imageAlt} loading="lazy" decoding="async" width="120" height="96" />
                </div>
              )}
              <div class="article-body">
                <h3>{isEn ? a.titleEn : a.title}</h3>
                <div class="article-author">
                  {isEn ? 'Author / ' : '作者 / '}
                  <b>{isEn ? a.authorEn : a.author}</b>
                </div>
              </div>
              <div class="article-arrow">→</div>
            </a>
          ))}
        </div>
      </div>

      <!-- Phonograph side: static logo with separately-spinning vinyl overlay -->
      <div class="phonograph-side">
        <div class="phonograph-wrap">
          <Image
            src={logoPhonograph}
            alt="新二代留聲機"
            class="phonograph-base"
            widths={[200, 400]}
            sizes="200px"
          />
          <div class="vinyl-spin" aria-hidden="true">
            <span class="vinyl-text">
              <span>新二代</span>
              <span>留聲機</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Submit CTA — closing invitation for the column section -->
    <div class="submit-cta">
      <div class="submit-text">
        <h3 class="submit-title">{isEn ? 'Submit Your Story' : '我要投稿'}</h3>
        <p class="submit-desc">
          {isEn
            ? 'Want to be the next contributor to New-Generation Phonograph? Reach out through any channel below.'
            : '想成為新二代留聲機的下一位作者？歡迎透過以下任一管道與我們聯繫。'}
        </p>
      </div>
      <div class="submit-channels">
        <a class="submit-email" href="mailto:2024tiya@gmail.com" aria-label={isEn ? 'Email us' : '寄信給我們'}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="M3 7l9 6 9-6"/>
          </svg>
          <span>2024tiya@gmail.com</span>
        </a>
        <a class="submit-icon" href="https://www.facebook.com/TWmigrantchamber/" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12C22 6.48 17.52 2 12 2S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
          </svg>
        </a>
        <a class="submit-icon" href="https://www.instagram.com/2023_tiya/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 28px 32px;
    background: var(--cream);
  }

  .section.warm {
    background: var(--cream-warm);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-h {
    font-size: 32px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 28px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .section-h::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 3px;
    background: var(--terra);
    align-self: center;
    flex-shrink: 0;
  }

  .accent {
    color: var(--terra-deep);
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 24px;
  }

  .column-layout {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 48px;
    align-items: center;
  }

  /* ── Phonograph ── */
  .phonograph-side {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phonograph-wrap {
    position: relative;
    width: 200px;
    height: 200px;
  }

  /* Static logo (turntable case + needle + outer terra-red disc) */
  .phonograph-base {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 50%;
    box-shadow:
      0 0 0 6px var(--cream-deep),
      0 8px 28px rgba(184, 64, 30, 0.22);
  }

  /* Spinning vinyl overlay — covers the static vinyl drawn into the logo image.
     Position/size tuned to align with the vinyl in logo-phonograph.png. */
  .vinyl-spin {
    position: absolute;
    top: 23%;
    left: 26%;
    width: 48%;
    height: 48%;
    border-radius: 50%;
    background:
      /* center pinhole */
      radial-gradient(circle at center, var(--ink) 0 2.5%, transparent 2.6% 100%),
      /* concentric grooves */
      repeating-radial-gradient(
        circle at center,
        #0a0a0a 0,
        #0a0a0a 2.5%,
        #1a1a1a 2.6%,
        #1a1a1a 3%
      ),
      /* base disc with subtle highlight */
      radial-gradient(circle at 35% 35%, #2a2a2a 0%, #0a0a0a 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: turntable 9s linear infinite;
    transform-origin: center;
  }

  .vinyl-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    font-family: 'Noto Serif TC', serif;
    font-size: 17px;
    font-weight: 700;
    color: white;
    letter-spacing: 0.1em;
    line-height: 1.05;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  @keyframes turntable {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Pause spin on hover so readers can read the label clearly */
  .phonograph-wrap:hover .vinyl-spin {
    animation-play-state: paused;
  }

  /* ── CW header ── */
  .cw-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 8px;
    font-size: 14px;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }

  .cw-badge {
    background: var(--terra-deep);
    color: white;
    padding: 6px 13px;
    font-size: 12px;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .cw-header a {
    color: var(--terra-deep);
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
    text-decoration: none;
    border-bottom: 1px solid var(--terra);
    padding-bottom: 1px;
    transition: color 0.15s;
  }

  .cw-header a:hover {
    color: var(--ink);
  }

  /* ── Article list ── */
  .articles-list {
    margin-top: 28px;
    border-top: 1px solid var(--line);
  }

  .article {
    display: grid;
    grid-template-columns: 60px 130px 1fr auto;
    gap: 22px;
    padding: 22px 16px;
    margin: 0 -16px;
    border-bottom: 1px solid var(--line);
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .article:hover {
    background: white;
  }

  .article-num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 36px;
    color: var(--terra-deep);
    font-weight: 500;
    line-height: 1;
    align-self: center;
  }

  .article-thumb {
    width: 130px;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    border-radius: 4px;
    background: var(--cream-warm);
  }

  .article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .article:hover .article-thumb img {
    transform: scale(1.05);
  }

  .article-body h3 {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.55;
    margin-bottom: 8px;
  }

  .article-author {
    font-size: 13px;
    color: var(--ink-soft);
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
  }

  .article-arrow {
    font-size: 18px;
    color: var(--terra);
    align-self: center;
    transition: transform 0.15s;
  }

  .article:hover .article-arrow {
    transform: translateX(4px);
  }

  /* ── Submit CTA: invitation panel below the article list ── */
  .submit-cta {
    margin-top: 40px;
    padding: 28px 32px;
    background: white;
    border-left: 3px solid var(--terra);
    border-radius: 2px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 28px;
    box-shadow: 0 1px 3px rgba(184, 64, 30, 0.06);
  }

  .submit-title {
    font-family: 'Noto Serif TC', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .submit-desc {
    font-size: 14px;
    line-height: 1.85;
    color: var(--ink-soft);
    margin: 0;
    max-width: 460px;
  }

  .submit-channels {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  /* Email pill: terra outline, fills on hover */
  .submit-email {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border: 1px solid var(--terra);
    border-radius: 999px;
    color: var(--terra-deep);
    text-decoration: none;
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .submit-email svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .submit-email:hover,
  .submit-email:focus-visible {
    background: var(--terra-deep);
    border-color: var(--terra-deep);
    color: white;
  }

  /* Circular icon buttons for FB / IG */
  .submit-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cream-warm);
    color: var(--terra-deep);
    border: 1px solid var(--line);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .submit-icon svg {
    width: 20px;
    height: 20px;
  }

  .submit-icon:hover,
  .submit-icon:focus-visible {
    background: var(--terra-deep);
    color: white;
    transform: translateY(-2px);
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .section {
      padding: 32px 20px;
    }

    .section-h {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .accent {
      font-size: 18px;
    }

    .column-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    /* Show phonograph FIRST on mobile — visual draw */
    .phonograph-side {
      order: -1;
    }

    .phonograph-wrap {
      width: 160px;
      height: 160px;
    }

    .vinyl-text {
      font-size: 13px;
      letter-spacing: 0.08em;
      gap: 2px;
    }

    .article {
      grid-template-columns: 36px 72px 1fr auto;
      gap: 12px;
      padding: 16px 8px;
      margin: 0 -8px;
    }

    .article-num {
      font-size: 26px;
    }

    .article-thumb {
      width: 72px;
    }

    .article-body h3 {
      font-size: 15px;
    }

    /* Submit CTA: stack on mobile so the channels sit below the invitation */
    .submit-cta {
      margin-top: 32px;
      padding: 22px 20px 20px;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .submit-title {
      font-size: 19px;
    }

    .submit-channels {
      gap: 10px;
      flex-wrap: wrap;
    }

    .submit-email {
      padding: 10px 14px;
      font-size: 12px;
      /* Allow the long email to wrap if needed — keeps button on one row otherwise */
      word-break: break-all;
    }

    .submit-icon {
      width: 42px;
      height: 42px;
    }
  }
</style>
