---
import { getCollection } from 'astro:content';

interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;
const isEn = lang === 'en';

const all = await getCollection('news', ({ data }) => data.featured !== false);
const items = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) =>
  isEn
    ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
    : `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<section class="section" id="news">
  <div class="container">
    <h2 class="section-h">
      {isEn ? 'In the News' : '媒體報導'}
      <span class="accent">news</span>
    </h2>

    <div class="news-carousel">
      <button class="carousel-btn prev" type="button" aria-label={isEn ? 'Previous' : '上一篇'} hidden>‹</button>

      <div
        class="news-scroll"
        data-news-scroll
        role="region"
        aria-label={isEn ? 'News coverage carousel' : '媒體報導列表'}
        tabindex="0"
      >
        {items.map(({ data: n }) => (
          <a class="news-card" href={n.url} target="_blank" rel="noopener">
            <div class="news-image">
              <img
                src={n.image}
                alt={isEn ? (n.imageAltEn ?? n.titleEn) : (n.imageAltZh ?? n.titleZh)}
                loading="lazy"
                decoding="async"
                width="600"
                height="338"
              />
              <span class="news-source">{isEn ? n.sourceEn : n.sourceZh}</span>
            </div>
            <div class="news-body">
              <h3 class="news-title">{isEn ? n.titleEn : n.titleZh}</h3>
              <p class="news-summary">{isEn ? n.summaryEn : n.summaryZh}</p>
              <div class="news-foot">
                <span class="news-date">{fmtDate(n.date)}</span>
                <span class="news-link">
                  {isEn ? 'Read →' : '閱讀全文 →'}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <button class="carousel-btn next" type="button" aria-label={isEn ? 'Next' : '下一篇'} hidden>›</button>
    </div>

    <div class="news-hint" aria-hidden="true">
      {isEn ? '← swipe to see more →' : '← 左右滑動查看更多 →'}
    </div>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-news-scroll]');
  carousels.forEach((scroller) => {
    const wrap = scroller.parentElement;
    if (!wrap) return;
    const prev = wrap.querySelector<HTMLButtonElement>('.carousel-btn.prev');
    const next = wrap.querySelector<HTMLButtonElement>('.carousel-btn.next');

    const step = () => {
      const card = scroller.querySelector<HTMLElement>('.news-card');
      if (!card) return scroller.clientWidth * 0.8;
      const style = getComputedStyle(scroller);
      const gap = parseFloat(style.columnGap || style.gap || '0') || 0;
      return card.getBoundingClientRect().width + gap;
    };

    const sync = () => {
      const max = scroller.scrollWidth - scroller.clientWidth;
      const overflowing = max > 2;
      if (!overflowing) {
        prev?.setAttribute('hidden', '');
        next?.setAttribute('hidden', '');
        return;
      }
      prev?.removeAttribute('hidden');
      next?.removeAttribute('hidden');
      prev?.toggleAttribute('disabled', scroller.scrollLeft <= 2);
      next?.toggleAttribute('disabled', scroller.scrollLeft >= max - 2);
    };

    prev?.addEventListener('click', () => scroller.scrollBy({ left: -step(), behavior: 'smooth' }));
    next?.addEventListener('click', () => scroller.scrollBy({ left: step(), behavior: 'smooth' }));
    scroller.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    requestAnimationFrame(sync);
  });
</script>

<style>
  .section {
    padding: 56px 32px;
    background: var(--cream);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-h {
    font-size: 32px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 28px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .section-h::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 3px;
    background: var(--terra);
    align-self: center;
    flex-shrink: 0;
  }

  .accent {
    color: var(--terra-deep);
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 24px;
  }

  /* ── Carousel wrap ── */
  .news-carousel {
    position: relative;
  }

  .news-scroll {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding: 4px;
    padding: 6px 4px 22px;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .news-scroll::-webkit-scrollbar {
    display: none;
  }

  .news-scroll:focus-visible {
    outline: 2px solid var(--terra);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ── Image-led cards: image dominates top, text supports below ── */
  .news-card {
    flex: 0 0 500px;
    scroll-snap-align: start;
    background: white;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 1px 3px rgba(184, 64, 30, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(184, 64, 30, 0.16);
  }

  /* Image area: 16:9 ratio, image fills via object-fit cover */
  .news-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--cream-warm);
    overflow: hidden;
  }

  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .news-card:hover .news-image img {
    transform: scale(1.04);
  }

  /* Source badge overlays the image top-left */
  .news-source {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--terra-deep);
    color: white;
    padding: 6px 12px;
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    border-radius: 2px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  /* Text block beneath image — supporting role */
  .news-body {
    padding: 22px 26px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .news-title {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.55;
    color: var(--ink);
    word-break: keep-all;
    overflow-wrap: break-word;
    /* Clamp to 2 lines on desktop — summary carries the explanatory text */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-summary {
    font-size: 14px;
    line-height: 1.85;
    color: var(--ink-soft);
    margin: 0;
    word-break: keep-all;
    overflow-wrap: break-word;
    /* 3-line excerpt keeps cards even-height regardless of summary length */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
    padding-top: 4px;
    border-top: 1px solid var(--line);
  }

  .news-date {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  .news-link {
    font-size: 13px;
    color: var(--terra-deep);
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: transform 0.15s ease;
  }

  .news-card:hover .news-link {
    transform: translateX(3px);
  }

  /* ── Prev/Next buttons (desktop only) ── */
  .carousel-btn {
    position: absolute;
    top: calc(50% - 22px); /* Center vertically on image area (excluding hint) */
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: white;
    border: 1px solid var(--line);
    color: var(--terra-deep);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
    box-shadow: 0 4px 14px rgba(184, 64, 30, 0.18);
    transition: background 0.15s, color 0.15s, opacity 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .carousel-btn.prev {
    left: -20px;
  }

  .carousel-btn.next {
    right: -20px;
  }

  .carousel-btn:hover:not([disabled]) {
    background: var(--terra-deep);
    color: white;
  }

  .carousel-btn[disabled] {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .carousel-btn[hidden] {
    display: none;
  }

  /* Mobile swipe hint */
  .news-hint {
    margin-top: 4px;
    text-align: center;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 12px;
    color: var(--ink-soft);
    opacity: 0.7;
    letter-spacing: 0.08em;
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .section {
      padding: 40px 20px;
    }

    .section-h {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .accent {
      font-size: 18px;
    }

    .news-scroll {
      gap: 16px;
      padding: 6px 0 18px;
      margin: 0 -20px;
      padding-left: 20px;
      padding-right: 20px;
      scroll-padding-left: 20px;
    }

    .news-card {
      flex-basis: 86vw;
      max-width: 340px;
    }

    .news-body {
      padding: 16px 18px 14px;
      gap: 12px;
    }

    .news-title {
      font-size: 15px;
      -webkit-line-clamp: 3;
    }

    /* Hide summary on mobile — keeps cards compact (user-approved layout) */
    .news-summary {
      display: none;
    }

    .news-source {
      font-size: 10px;
      padding: 4px 9px;
    }

    .carousel-btn {
      display: none !important;
    }
  }

  @media (min-width: 769px) {
    .news-hint {
      display: none;
    }
  }
</style>
