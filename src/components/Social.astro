---
interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;
const isEn = lang === 'en';
---

<section class="section" id="contact">
  <div class="container">
    <h2 class="section-h">
      {isEn ? 'Follow Us' : '追蹤我們'}
      <span class="accent">follow</span>
    </h2>

    <div class="social-row">
      <a class="social-card" href="https://www.facebook.com/TWmigrantchamber/" target="_blank" rel="noopener">
        <div class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12C22 6.48 17.52 2 12 2S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
          </svg>
        </div>
        <div class="social-info">
          <b>Facebook</b>
          <span>facebook.com/TWmigrantchamber</span>
        </div>
        <div class="social-arrow">→</div>
      </a>

      <a class="social-card" href="https://www.instagram.com/2023_tiya/" target="_blank" rel="noopener">
        <div class="social-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
        </div>
        <div class="social-info">
          <b>Instagram</b>
          <span>instagram.com/2023_tiya</span>
        </div>
        <div class="social-arrow">→</div>
      </a>

      <a class="social-card" href="https://www.threads.com/@2023_tiya" target="_blank" rel="noopener">
        <div class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717-1.337 1.665-2.028 4.075-2.055 7.161.027 3.086.718 5.496 2.055 7.161 1.43 1.781 3.631 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.508-.575-1.292-.866-2.331-.874-.014 0-.025 0-.04 0-.834 0-1.965.231-2.687 1.305L7.34 8.587c.97-1.439 2.547-2.231 4.45-2.231h.058c3.183.02 5.082 1.969 5.271 5.376.108.045.215.094.32.143 1.49.7 2.58 1.76 3.154 3.067.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65zm1.003-11.69c-.327 0-.66.01-.999.028-1.844.103-2.993.948-2.927 2.15.067 1.26 1.452 1.847 2.79 1.776 1.23-.066 2.836-.544 3.106-3.717a10.586 10.586 0 0 0-1.97-.236z"/>
          </svg>
        </div>
        <div class="social-info">
          <b>Threads</b>
          <span>threads.com/@2023_tiya</span>
        </div>
        <div class="social-arrow">→</div>
      </a>
    </div>

    <div class="email-row">
      <span class="email-label">{isEn ? 'Contact / Submissions' : '聯絡 / 投稿'}</span>
      <a href="mailto:2024tiya@gmail.com" class="email-link">2024tiya@gmail.com</a>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 56px 32px;
    background: var(--cream);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-h {
    font-size: 32px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 28px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .section-h::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 3px;
    background: var(--terra);
    align-self: center;
    flex-shrink: 0;
  }

  .accent {
    color: var(--terra-deep);
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 24px;
  }

  .social-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 8px;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 22px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s, border-color 0.15s;
  }

  .social-card:hover {
    transform: translateY(-2px);
    border-color: var(--terra);
  }

  .social-icon {
    color: var(--terra-deep);
    flex-shrink: 0;
  }

  .social-icon svg {
    width: 28px;
    height: 28px;
  }

  .social-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .social-info b {
    font-size: 15px;
    font-weight: 600;
  }

  .social-info span {
    font-size: 13px;
    color: var(--ink-soft);
    font-family: 'IBM Plex Sans', sans-serif;
  }

  .social-arrow {
    color: var(--terra);
    font-size: 16px;
  }

  .email-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    font-size: 14px;
  }

  .email-label {
    color: var(--ink-soft);
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
  }

  .email-link {
    color: var(--terra-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--terra);
    padding-bottom: 1px;
    font-family: 'IBM Plex Sans', sans-serif;
  }

  .email-link:hover {
    color: var(--ink);
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .section {
      padding: 40px 20px;
    }

    .section-h {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .accent {
      font-size: 18px;
    }

    .social-row {
      grid-template-columns: 1fr;
    }

    .email-row {
      flex-wrap: wrap;
      gap: 8px;
    }

    .email-link {
      word-break: break-all;
    }
  }
</style>
