---
interface Props {
  lang?: string;
}
const { lang = 'zh-TW' } = Astro.props;
const isEn = lang === 'en';
---

<section class="section" id="contact">
  <div class="container">
    <h2 class="section-h">
      {isEn ? 'Follow Us' : '追蹤我們'}
      <span class="accent">follow</span>
    </h2>

    <div class="social-row">
      <a class="social-card" href="https://www.facebook.com/TWmigrantchamber/" target="_blank" rel="noopener">
        <div class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12C22 6.48 17.52 2 12 2S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
          </svg>
        </div>
        <div class="social-info">
          <b>Facebook</b>
          <span>facebook.com/TWmigrantchamber</span>
        </div>
        <div class="social-arrow">→</div>
      </a>

      <a class="social-card" href="https://www.instagram.com/2023_tiya/" target="_blank" rel="noopener">
        <div class="social-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
        </div>
        <div class="social-info">
          <b>Instagram</b>
          <span>instagram.com/2023_tiya</span>
        </div>
        <div class="social-arrow">→</div>
      </a>
    </div>

    <div class="email-row">
      <span class="email-label">{isEn ? 'Contact / Submissions' : '聯絡 / 投稿'}</span>
      <a href="mailto:2024tiya@gmail.com" class="email-link">2024tiya@gmail.com</a>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 56px 32px;
    background: var(--cream);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-h {
    font-size: 32px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 28px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .section-h::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 3px;
    background: var(--terra);
    align-self: center;
    flex-shrink: 0;
  }

  .accent {
    color: var(--terra-deep);
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 24px;
  }

  .social-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 8px;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 22px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s, border-color 0.15s;
  }

  .social-card:hover {
    transform: translateY(-2px);
    border-color: var(--terra);
  }

  .social-icon {
    color: var(--terra-deep);
    flex-shrink: 0;
  }

  .social-icon svg {
    width: 28px;
    height: 28px;
  }

  .social-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .social-info b {
    font-size: 15px;
    font-weight: 600;
  }

  .social-info span {
    font-size: 12px;
    color: var(--ink-soft);
    font-family: 'IBM Plex Sans', sans-serif;
  }

  .social-arrow {
    color: var(--terra);
    font-size: 16px;
  }

  .email-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    font-size: 13px;
  }

  .email-label {
    color: var(--ink-soft);
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
  }

  .email-link {
    color: var(--terra-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--terra);
    padding-bottom: 1px;
    font-family: 'IBM Plex Sans', sans-serif;
  }

  .email-link:hover {
    color: var(--ink);
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .section {
      padding: 40px 20px;
    }

    .section-h {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .accent {
      font-size: 18px;
    }

    .social-row {
      grid-template-columns: 1fr;
    }

    .email-row {
      flex-wrap: wrap;
      gap: 8px;
    }

    .email-link {
      word-break: break-all;
    }
  }
</style>
