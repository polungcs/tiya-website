---
interface Props {
  current?: string;
}
const { current = 'zh-TW' } = Astro.props;

const langs = [
  { code: 'zh-TW', label: '繁體中文', href: '/' },
  { code: 'zh-CN', label: '简体中文', href: '#' },
  { code: 'en',    label: 'English',  href: '/en/' },
  { code: 'vi',    label: 'Tiếng Việt',     href: '#' },
  { code: 'id',    label: 'Bahasa Indonesia', href: '#' },
  { code: 'ms',    label: 'Bahasa Melayu',  href: '#' },
  { code: 'tl',    label: 'Tagalog',        href: '#' },
  { code: 'th',    label: 'ภาษาไทย',        href: '#' },
  { code: 'km',    label: 'ភាសាខ្មែរ',       href: '#' },
  { code: 'lo',    label: 'ພາສາລາວ',        href: '#' },
  { code: 'my',    label: 'မြန်မာ',          href: '#' },
];
---

<div class="lang-bar">
  {langs.map(l => (
    <a href={l.href} class={l.code === current ? 'on' : ''}>{l.label}</a>
  ))}
</div>

<style>
  .lang-bar {
    background: var(--cream-warm);
    border-bottom: 1px solid var(--line);
    padding: 9px 24px;
    display: flex;
    flex-wrap: wrap;
    font-size: 12px;
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
  }

  .lang-bar a {
    color: var(--ink-soft);
    padding: 4px 12px;
    border-right: 1px solid var(--line);
    cursor: pointer;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s;
    position: relative;
  }

  .lang-bar a:last-child {
    border-right: 0;
  }

  .lang-bar a:hover {
    color: var(--terra-deep);
  }

  .lang-bar a.on {
    color: var(--terra-deep);
    font-weight: 600;
  }

  .lang-bar a.on::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: -10px;
    height: 2px;
    background: var(--terra-deep);
  }
</style>
