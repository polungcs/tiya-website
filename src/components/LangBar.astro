---
interface Props {
  current?: string;
}
const { current = 'zh-TW' } = Astro.props;

// 第一階段只做繁中 + 英文。其他東南亞語言之後翻譯到位再加回來。
const langs = [
  { code: 'zh-TW', label: '繁體中文', href: '/' },
  { code: 'en',    label: 'English',  href: '/en/' },
];
---

<div class="lang-bar">
  {langs.map(l => (
    <a href={l.href} class={l.code === current ? 'on' : ''}>{l.label}</a>
  ))}
</div>

<style>
  .lang-bar {
    background: var(--cream-warm);
    border-bottom: 1px solid var(--line);
    padding: 9px 24px;
    display: flex;
    flex-wrap: wrap;
    font-size: 12px;
    font-family: 'IBM Plex Sans', 'Noto Sans TC', sans-serif;
  }

  .lang-bar a {
    color: var(--ink-soft);
    padding: 4px 12px;
    border-right: 1px solid var(--line);
    cursor: pointer;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s;
    position: relative;
  }

  .lang-bar a:last-child {
    border-right: 0;
  }

  .lang-bar a:hover {
    color: var(--terra-deep);
  }

  .lang-bar a.on {
    color: var(--terra-deep);
    font-weight: 600;
  }

  .lang-bar a.on::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: -10px;
    height: 2px;
    background: var(--terra-deep);
  }

  /* ── Mobile (≤768px) ── */
  @media (max-width: 768px) {
    .lang-bar {
      padding: 6px 12px;
      font-size: 11px;
      gap: 0;
    }

    .lang-bar a {
      padding: 3px 8px;
    }

    .lang-bar a.on::after {
      left: 8px;
      right: 8px;
      bottom: -6px;
    }
  }
</style>
